---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Contact & Admissions | St. Claret College of Nursing" activeNav="">

  <!-- ============ HERO ============ -->
  <section class="relative py-32 overflow-hidden">
    <img
      src={`${base}/images/figma/job-05015.jpg`}
      alt="Contact us"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-navy/90"></div>
    <div class="relative max-w-container mx-auto px-8 text-center flex flex-col items-center gap-6">
      <span class="font-work-sans font-semibold text-gold text-sm uppercase tracking-[2.8px]">Get in Touch</span>
      <h1 class="font-newsreader italic text-5xl md:text-7xl text-white leading-tight">
        Contact & Admissions
      </h1>
      <p class="text-[#FBF6E3] text-xl max-w-2xl leading-relaxed">
        Have questions about our programs? Ready to apply? Reach out to us — we're here to help you start your nursing career.
      </p>
    </div>
  </section>

  <!-- ============ CONTACT FORM + INFO ============ -->
  <section class="bg-light-bg px-8 py-24">
    <div class="max-w-container mx-auto grid grid-cols-1 lg:grid-cols-5 gap-16">

      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <div class="bg-white rounded-lg shadow-md p-10">
          <h2 class="font-newsreader italic text-3xl text-navy mb-2">Send Us a Message</h2>
          <p class="text-text-secondary text-base mb-8">Fill out the form below and our admissions team will get back to you within 24 hours.</p>

          <form class="flex flex-col gap-6" action="#" method="POST">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="name" class="font-work-sans font-semibold text-navy text-sm uppercase tracking-wider">Full Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Enter your full name"
                  class="border border-gray-300 rounded-md px-4 py-3 text-base focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label for="phone" class="font-work-sans font-semibold text-navy text-sm uppercase tracking-wider">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+91 XXXXX XXXXX"
                  class="border border-gray-300 rounded-md px-4 py-3 text-base focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
                />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="font-work-sans font-semibold text-navy text-sm uppercase tracking-wider">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your.email@example.com"
                class="border border-gray-300 rounded-md px-4 py-3 text-base focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="program" class="font-work-sans font-semibold text-navy text-sm uppercase tracking-wider">Program of Interest</label>
              <select
                id="program"
                name="program"
                class="border border-gray-300 rounded-md px-4 py-3 text-base focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold bg-white"
              >
                <option value="">Select a program</option>
                <option value="bsc">B.Sc Nursing (4 Years)</option>
                <option value="gnm">GNM Nursing (3.5 Years)</option>
                <option value="bridge">Bridge Course</option>
                <option value="other">Other / General Inquiry</option>
              </select>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="font-work-sans font-semibold text-navy text-sm uppercase tracking-wider">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us about yourself and any questions you have..."
                class="border border-gray-300 rounded-md px-4 py-3 text-base focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="bg-navy text-white font-work-sans font-semibold text-base px-8 py-4 rounded-md hover:bg-navy/90 transition-colors self-start"
            >
              Submit Inquiry
            </button>
          </form>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="lg:col-span-2 flex flex-col gap-8">
        <!-- Address -->
        <div class="bg-white rounded-lg shadow-md p-8 flex flex-col gap-6">
          <h3 class="font-newsreader italic text-2xl text-navy">Visit Us</h3>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-4">
              <div class="bg-blue-light rounded-lg p-3 flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h4 class="font-work-sans font-semibold text-navy text-sm">Campus Address</h4>
                <p class="text-text-secondary text-base mt-1">
                  St. Claret College of Nursing<br />
                  Veeraiah Nagar, Arasinakunte<br />
                  Dasanapura, Karnataka - 562162<br />
                  India
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-blue-light rounded-lg p-3 flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h4 class="font-work-sans font-semibold text-navy text-sm">Phone</h4>
                <a href="tel:+919035900065" class="text-navy font-bold text-base mt-1 block hover:text-gold transition-colors">
                  +91 90359 00065
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-blue-light rounded-lg p-3 flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h4 class="font-work-sans font-semibold text-navy text-sm">Email</h4>
                <a href="mailto:admission@stclaretcollegeofnursing.com" class="text-gold-dark font-bold text-base mt-1 block hover:text-gold transition-colors">
                  admission@stclaretcollegeofnursing.com
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Office Hours -->
        <div class="bg-navy rounded-lg p-8 flex flex-col gap-6">
          <h3 class="font-newsreader italic text-2xl text-white">Office Hours</h3>
          <div class="flex flex-col gap-3">
            {[
              { day: 'Monday — Friday', time: '9:00 AM — 5:00 PM' },
              { day: 'Saturday', time: '9:00 AM — 1:00 PM' },
              { day: 'Sunday', time: 'Closed' },
            ].map((item) => (
              <div class="flex items-center justify-between border-b border-white/10 pb-3">
                <span class="text-slate-300 text-base">{item.day}</span>
                <span class="font-work-sans font-semibold text-gold text-sm">{item.time}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-lg shadow-md p-8 flex flex-col gap-4">
          <h3 class="font-newsreader italic text-2xl text-navy">Quick Actions</h3>
          <a href="#" class="flex items-center justify-between bg-gold/10 rounded-md px-5 py-4 group hover:bg-gold/20 transition-colors">
            <span class="font-work-sans font-semibold text-navy text-sm">Download Prospectus</span>
            <svg class="w-5 h-5 text-gold group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </a>
          <a href="#" class="flex items-center justify-between bg-navy/5 rounded-md px-5 py-4 group hover:bg-navy/10 transition-colors">
            <span class="font-work-sans font-semibold text-navy text-sm">Application Form</span>
            <svg class="w-5 h-5 text-navy group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </a>
          <a href="#" class="flex items-center justify-between bg-navy/5 rounded-md px-5 py-4 group hover:bg-navy/10 transition-colors">
            <span class="font-work-sans font-semibold text-navy text-sm">Schedule Campus Visit</span>
            <svg class="w-5 h-5 text-navy group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MAP ============ -->
  <section class="bg-white px-8 py-24">
    <div class="max-w-container mx-auto">
      <div class="text-center mb-12 flex flex-col items-center gap-4">
        <span class="font-work-sans font-semibold text-navy text-sm uppercase tracking-[2.8px]">Location</span>
        <h2 class="font-newsreader italic text-4xl text-navy">Find Us on the Map</h2>
      </div>
      <div class="rounded-lg overflow-hidden shadow-md h-[400px] bg-blue-light flex items-center justify-center">
        <iframe
          src="https://www.google.com/maps?q=Veeraiah+Nagar,+Arasinakunte,+Dasanapura,+Karnataka+562162&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="St. Claret College of Nursing Location"
        ></iframe>
      </div>
    </div>
  </section>

</BaseLayout>
