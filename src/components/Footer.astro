---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const programLinks = [
  { label: 'B.Sc Nursing', href: `${base}/courses#bsc` },
  { label: 'GNM Nursing', href: `${base}/courses#gnm` },
  { label: 'Post Basic B.Sc', href: `${base}/courses#pbbsc` },
  { label: 'M.Sc Nursing', href: `${base}/courses#msc` },
];

const quickLinks = [
  { label: 'Privacy Policy', href: `${base}/privacy` },
  { label: 'Terms of Service', href: `${base}/terms` },
  { label: 'Contact Us', href: `${base}/contact` },
];
---

<footer class="bg-[#001F3F]">
  <div class="max-w-container mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 px-12 pt-16 pb-16 border-b border-[#0a1228]">
    <!-- Column 1: Logo & Description -->
    <div class="flex flex-col gap-6">
      <a href={`${base}/`} aria-label="St. Claret College of Nursing - Home" class="bg-white rounded-md p-3 inline-flex self-start">
        <img
          src={`${base}/images/logo.png`}
          alt="St. Claret College of Nursing"
          class="h-12 w-auto"
        />
      </a>
      <p class="text-slate-400 text-sm leading-relaxed">
        Pioneering nursing education in Bangalore with a commitment to producing compassionate healthcare leaders since 1998. Exclusively for female students.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://www.instagram.com/stclaretnursing/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-slate-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.youtube.com/@bharathiinstitutions" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-slate-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Programs -->
    <div class="flex flex-col gap-6">
      <h3 class="font-work-sans font-semibold text-sm text-white uppercase tracking-widest">Programs</h3>
      <ul class="flex flex-col gap-4">
        {programLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Quick Links -->
    <div class="flex flex-col gap-6">
      <h3 class="font-work-sans font-semibold text-sm text-white uppercase tracking-widest">Quick Links</h3>
      <ul class="flex flex-col gap-4">
        {quickLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div class="flex flex-col gap-6">
      <h3 class="font-work-sans font-semibold text-sm text-white uppercase tracking-widest">Contact Us</h3>
      <p class="text-slate-400 text-sm leading-relaxed">
        St. Claret College of Nursing,<br />
        Veeraiah Nagar, Arasinakunte,<br />
        Dasanapura, Karnataka - 562162
      </p>
      <a href="mailto:admission@stclaretcollegeofnursing.com" class="text-amber-400 font-bold text-base hover:text-amber-300 transition-colors">
        admission@stclaretcollegeofnursing.com
      </a>
      <a href="tel:+919847139798" class="text-white font-bold text-base hover:text-slate-300 transition-colors">
        +91 98471 39798
      </a>
    </div>
  </div>

  <div class="text-center py-8 px-12 flex flex-col gap-2">
    <p class="text-slate-400 text-xs uppercase tracking-widest">
      &copy; 2026 St. Claret College of Nursing. Excellence in Healthcare Education.
    </p>
    <p class="text-slate-500 text-xs">
      Developed by <a href="https://neuflo.io" target="_blank" rel="noopener noreferrer" class="text-amber-400 hover:text-amber-300 transition-colors">Neuflo.io</a>
    </p>
  </div>
</footer>
